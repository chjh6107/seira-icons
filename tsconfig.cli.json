{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "bin/**/*.js",
    "src/cli/**/*.js",
    "scripts/generate/**/*.js",
    "test/cli/**/*.ts",
    "test/generate/**/*.ts"
  ]
}
